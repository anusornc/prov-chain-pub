            epcis:value "4.1"^^xsd:double ;
            epcis:uom "CEL"
        ]
    ] .

#################################################################
# Master Data - Product Information
#################################################################

<urn:epc:id:gtin:12345678901234> a gs1:Product ;
    gs1:gtin "12345678901234" ;
    gs1:productName "Raw Organic Whole Milk" ;
    gs1:productDescription "Fresh raw milk from grass-fed cows" .

<urn:epc:id:gtin:12345678901235> a gs1:MilkButterCreamYogurtCheeseEggsSubstitutes ;
    gs1:gtin "12345678901235" ;
    gs1:productName "Organic UHT Whole Milk" ;
    gs1:productDescription "Ultra-High Temperature processed organic milk" ;
    gs1:preservationTechnique gs1:PreservationTechnique-UHT ;
    gs1:storageTemperatureType gs1:StorageTemperatureType-AMBIENT ;
    gs1:shelfLife "P180D"^^xsd:duration ;
    gs1:fatInDryMatter "4.0"^^xsd:decimal ;
    gs1:milkFatPercentage "4.0"^^xsd:decimal ;
    gs1:ingredientStatement "Organic whole milk, vitamin D3" ;
    gs1:allergenInformation [
        gs1:allergenType gs1:AllergenType-MILK ;
        gs1:levelOfContainment gs1:LevelOfContainment-CONTAINS
    ] .

<urn:epc:id:gtin:12345678901236> a gs1:Product ;
    gs1:gtin "12345678901236" ;
    gs1:productName "Organic UHT Milk 1L Carton" .
